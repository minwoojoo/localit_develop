### 회원가입
POST https://us-central1-localit-ef984.cloudfunctions.net/registerUser
Content-Type: application/json

{
  "data": {
    "uid": "local04",
    "email": "local04@example.com",
    "nickname": "로컬유저",
    "type": "traveler",
    "phone_number": "010-9999-8888",
    "languages": ["ko"],
    "profileImageUrl": "https://...",
    "certified": true,
    "age": 28,
    "gender": "남",
    "preferred_meetup": "오프",
    "preferred_location": "Hongdae",
    "interests": ["food", "culture"],
    "hobbies": "등산, 사진",
    "verification_data": { "ocr_id_image": "filename.jpg" },
    "verification_status": "approved"
  }
}














### 사용자 정보 조회
POST http://localhost:5001/localit-ef984/us-central1/getUserProfile
Content-Type: application/json

{
  "data": {
    "uid": "test123"
  }
}

### 사용자 정보 수정
POST http://localhost:5001/localit-ef984/us-central1/updateUserProfile
Content-Type: application/json

{
  "data": {
    "uid": "test123",
    "nickname": "수정된닉네임",
    "languages": ["한국어", "영어", "일본어"]
  }
}

### 매칭 요청
POST http://localhost:5001/localit-ef984/us-central1/requestMatching
Content-Type: application/json

{
  "data": {
    "requester_id": "user123",
    "receiver_id": "local456",
    "travel_info": {
      "start_date": "2024-03-20",
      "end_date": "2024-03-25",
      "location": "서울",
      "preferences": ["맛집", "문화"]
    }
  }
}

### 매칭 수락
POST http://localhost:5001/localit-ef984/us-central1/acceptMatching
Content-Type: application/json

{
  "data": {
    "matchingId": "matching123"
  }
}

### 채팅 메시지 전송
POST http://localhost:5001/localit-ef984/us-central1/postMessage
Content-Type: application/json

{
  "data": {
    "chat_room_id": "room123",
    "sender_id": "user123",
    "message": "안녕하세요!"
  }
}

### 여행객 소개글 등록
POST http://localhost:5001/localit-ef984/us-central1/postTravelerIntro
Content-Type: application/json

{
  "data": {
    "traveler_id": "user123",
    "title": "서울 여행 같이 해요!",
    "content": "3월 20일부터 25일까지 서울 여행 계획 중입니다.",
    "location": "서울",
    "preferred_meetup": "홍대",
    "travel_theme": ["맛집", "문화"]
  }
} 